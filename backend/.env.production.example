# =============================================================================
# Better Golf — Production Environment Variables (Heroku Container Registry)
# =============================================================================
# Copy this file to backend/.env.production and fill in all values.
# backend/.env.production is gitignored and must NEVER be committed.
#
# This file is read by scripts/deploy-backend.sh to push config vars to Heroku.
# All keys below are required unless marked optional.
# =============================================================================

# Django secret key — generate a strong random value (50+ characters)
# Example: python -c "import secrets; print(secrets.token_urlsafe(50))"
SECRET_KEY=

# Must be False in production
DEBUG=False

# Comma-separated list of allowed hostnames (no spaces)
# Include your Heroku app domain and any custom API domain
# Example: my-app.herokuapp.com,api.mydomain.com
ALLOWED_HOSTS=

# External managed PostgreSQL connection URL
# Example: postgres://user:password@host:5432/dbname
DATABASE_URL=

# Golf Course API credentials
GOLF_COURSE_API_KEY=
GOLF_COURSE_API_URL=https://api.golfcourseapi.com

# Comma-separated list of allowed CORS origins (no spaces)
# Include all frontend origins: Netlify default domain + any custom domain
# Example: https://my-app.netlify.app,https://www.mydomain.com
CORS_ALLOWED_ORIGINS=

# Must be False in production
CORS_ALLOW_ALL_ORIGINS=False
