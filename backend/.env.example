SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# For local development, use SQLite
DATABASE_ENGINE=django.db.backends.sqlite3
DATABASE_NAME=db.sqlite3

# For production (Heroku), DATABASE_URL is automatically set by Heroku PostgreSQL addon
# DATABASE_URL=postgres://user:password@host:port/dbname

GOLF_COURSE_API_KEY=your-golf-course-api-key-here
GOLF_COURSE_API_URL=https://api.golfcourseapi.com

# For local development
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:19006

# For production, add your Netlify URL
# CORS_ALLOWED_ORIGINS=https://your-app.netlify.app

CORS_ALLOW_ALL_ORIGINS=True
